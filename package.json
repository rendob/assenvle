{
  "name": "assenvle",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "assenvle": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "check": "concurrently -c auto npm:check:*",
    "check:biome": "biome check",
    "check:tsc": "tsc --noEmit",
    "fix": "biome check --write",
    "test": "npm run build && vitest run",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rendob/assenvle.git"
  },
  "author": "rendob",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "bugs": {
    "url": "https://github.com/rendob/assenvle/issues"
  },
  "homepage": "https://github.com/rendob/assenvle#readme",
  "description": "Merge environment variables for a given mode into a single file.",
  "dependencies": {
    "@inquirer/prompts": "^7.8.0",
    "chokidar": "^4.0.3",
    "commander": "^14.0.0",
    "dotenv": "^17.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@tsconfig/node24": "^24.0.1",
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "^24.1.0",
    "concurrently": "^9.2.0",
    "husky": "^9.1.7",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
