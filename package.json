{
  "name": "assenvle",
  "version": "0.1.0",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "assenvle": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "check": "concurrently -c auto npm:check:*",
    "check:biome": "biome check",
    "check:tsc": "tsc --noEmit",
    "fix": "biome check --write",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rendob/assenvle.git"
  },
  "author": "rendob",
  "license": "MIT",
  "files": ["dist", "src"],
  "bugs": {
    "url": "https://github.com/rendob/assenvle/issues"
  },
  "homepage": "https://github.com/rendob/assenvle#readme",
  "description": "Merge environment variables for a given mode into a single file.",
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@tsconfig/node24": "^24.0.0",
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "^22.15.17",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "typescript": "^5.8.3"
  },
  "volta": {
    "node": "24.0.1"
  }
}
